#include <stdio.h>
#include <stdlib.h>

int main() {
    char operacao;
    double num1, num2, resultado;

    printf("--- CALCULADORA SIMPLES ---\n");
    printf("Escolha a operacao (+, -, *, /): ");
    scanf(" %c", &operacao); 

    printf("Digite o primeiro numero: ");
    scanf("%lf", &num1);
    
    printf("Digite o segundo numero: ");
    scanf("%lf", &num2);

    switch (operacao) {
        case '+':
            resultado = num1 + num2;
            printf("Resultado: %.2lf + %.2lf = %.2lf\n", num1, num2, resultado);
            break;
            
        case '-':
            resultado = num1 - num2;
            printf("Resultado: %.2lf - %.2lf = %.2lf\n", num1, num2, resultado);
            break;
            
        case '*':
            resultado = num1 * num2;
            printf("Resultado: %.2lf * %.2lf = %.2lf\n", num1, num2, resultado);
            break;
            
        case '/':
      
            if (num2 != 0) {
                resultado = num1 / num2;
                printf("Resultado: %.2lf / %.2lf = %.2lf\n", num1, num2, resultado);
            } else {
                printf("Erro: Divisao por zero nao eh permitida!\n");
            }
            break;
            
        default:
            printf("Erro: Operacao invalida!\n");
    }

    return 0;
}
